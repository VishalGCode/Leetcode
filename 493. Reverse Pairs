class Solution {
    void merge(int[] nums, int s, int m, int e) {
        int[] temp = new int[e - s + 1];
        int l = s, r = m + 1, k = 0;
        while (l <= m && r <= e) {
            if (nums[l] <= nums[r]) temp[k++] = nums[l++];
            else temp[k++] = nums[r++];
        }
        while (l <= m) temp[k++] = nums[l++];
        while (r <= e) temp[k++] = nums[r++];
        for (int i = 0; i < temp.length; i++) nums[s + i] = temp[i];
    }
    int countPairs(int[] nums, int s, int m, int e) {
        int count = 0, r = m + 1;
        for (int i = s; i <= m; i++) {
            while (r <= e && (long) nums[i] > 2L * nums[r]) r++;
            count += (r - (m + 1));
        }
        return count;
    }
    int mergeSort(int[] nums, int s, int e) {
        if (s >= e) return 0;
        int m = s + (e - s) / 2, count = 0;
        count += mergeSort(nums, s, m);
        count += mergeSort(nums, m + 1, e);
        count += countPairs(nums, s, m, e);
        merge(nums, s, m, e);
        return count;
    }
    public int reversePairs(int[] nums) {
        return mergeSort(nums, 0, nums.length - 1);
    }
}
